<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(TargetFrameworkVersions)</TargetFrameworks>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Debug: ProjectReference to ploch-common for easier debugging -->
  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\..\..\ploch-common\src\Common.AppServices\Ploch.Common.AppServices.csproj" />
    <ProjectReference Include="..\..\..\..\ploch-common\src\Common\Ploch.Common.csproj" />
  </ItemGroup>
  <!-- Release: PackageReference (versions from Directory.Packages.props) -->
  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="Ploch.Common.AppServices" />
    <PackageReference Include="Ploch.Common" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Data.Model\Ploch.Data.Model.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

</Project>
